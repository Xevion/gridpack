{
	"name": "gridpack",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "tempo check",
		"check:types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"fmt": "tempo fmt",
		"hooks:install": "lefthook install",
		"knip": "knip",
		"lint": "tempo lint",
		"prepare": "panda codegen && svelte-kit sync && lefthook install || echo ''",
		"preview": "vite preview",
		"sort:pkg": "sort-package-json",
		"spell": "cspell --no-progress --gitignore \"**/*.{ts,js,svelte,md}\""
	},
	"dependencies": {
		"@ark-ui/svelte": "^5.21.0",
		"@fontsource-variable/playfair-display": "^5.2.8",
		"@fontsource/source-sans-pro": "^5.2.5"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint/js": "^10.0.1",
		"@pandacss/dev": "^1.9.1",
		"@pandacss/eslint-plugin": "^0.3.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@xevion/tempo": "^0.1.4",
		"cspell": "^10.0.1",
		"eslint": "^10.4.1",
		"eslint-plugin-perfectionist": "^5.9.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"knip": "^6.15.0",
		"lefthook": "^2.1.9",
		"postcss": "^8.5.15",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"sort-package-json": "^4.0.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.7"
	},
	"packageManager": "bun@1.3.11"
}
